-- SISTEMA DE DRAG
-- ============================================
local TopBar = Instance.new("Frame")
TopBar.Name = "TopBar"
TopBar.Parent = MainFrame
TopBar.Position = UDim2.new(0, 0, 0, 0)
TopBar.Size = UDim2.new(1, 0, 0, 60)
TopBar.BackgroundTransparency = 1
TopBar.BorderSizePixel = 0

local dragging
local dragInput
local dragStart
local startPos
local leftStartPos

local function update(input)
    local delta = input.Position - dragStart
    MainFrame.Position = UDim2.new(
        startPos.X.Scale,
        startPos.X.Offset + delta.X,
        startPos.Y.Scale,
        startPos.Y.Offset + delta.Y
    )
    LeftPanel.Position = UDim2.new(
        leftStartPos.X.Scale,
        leftStartPos.X.Offset + delta.X,
        leftStartPos.Y.Scale,
        leftStartPos.Y.Offset + delta.Y
    )
end

TopBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
        leftStartPos = LeftPanel.Position

        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

TopBar.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        update(input)
    end
end)

-- Funcionalidade dos botões
CloseButton.MouseButton1Click:Connect(function()
    ScreenGui:Destroy()
end)

local function toggleMinimize()
    MainFrame.Visible = not MainFrame.Visible
    LeftPanel.Visible = not LeftPanel.Visible
end

MinimizeButton.MouseButton1Click:Connect(toggleMinimize)

-- Tecla B para minimizar
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.B then
        toggleMinimize()
    end
end)

